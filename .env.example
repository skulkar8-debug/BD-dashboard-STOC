# Instantly API V2 keys — one per org
# Get these from: Instantly workspace → Settings → Integrations → API Keys
# Use the full raw key value exactly as-is. Do NOT decode, split, or transform.
# Authorization: Bearer <full_raw_key>

INSTANTLY_MY_ORG_API_KEY=
INSTANTLY_EMBARK_API_KEY=
INSTANTLY_SUN_AUTO_API_KEY=
INSTANTLY_AEG_VISION_API_KEY=
INSTANTLY_MCLERRAN_API_KEY=
INSTANTLY_BRANTA_API_KEY=
INSTANTLY_CORVIA_API_KEY=

# ─── Google OAuth (Sheets API) ───────────────────────────────────────────────
# 1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client (Web)
# 2. Authorized redirect URI: http://localhost:3000/api/auth/google/callback
#    (and your production URL, e.g. https://your-app.vercel.app/api/auth/google/callback)
# 3. Enable "Google Sheets API" for the project
# 4. The signed-in Google account must have Editor access to the spreadsheets below
# 5. If you see "insufficient authentication scopes", disconnect and reconnect Google
#    (old read-only tokens must be replaced with read+write permission)

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Random secret used to sign the OAuth session cookie (e.g. openssl rand -base64 32)
AUTH_SECRET=

# App URL for OAuth redirects (required in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — override default spreadsheet IDs
# GOOGLE_ROADMAP_SHEET_ID=1wqW8zgy2E_W6I5S_wi9iDqA4OWC0B74zd6l6_v3uQpo
# GOOGLE_PIPELINE_SHEET_ID=1x36UMX4T21Jc0Uv1WCSiCuYyLRK860rKzZpRet7xH_Y
# GOOGLE_PIPELINE_TAB=Sheet1
